# ===== PostgreSQL (packages/backend) =====
# 开发库（docker-compose POSTGRES_DB）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cool_dev

# 测试库（docker/docker-compose.yml init-db.sql 自动创建）
# 真实多租户隔离测试 tests/real-tenant.test.mjs 使用此库。
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=cool_test

# ===== cool-admin v8 gate =====
# 可选：外部 cool-admin v8 checkout 路径（默认校验 vendored packages/backend）。
# COOL_ADMIN_PATH=E:\work\vendor\cool-admin-midway-v8
