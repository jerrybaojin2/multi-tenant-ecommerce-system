{
  "name": "@miniapp-rent/backend",
  "version": "0.1.0-pr0",
  "description": "Self-built Midway.js backend for the multi-tenant rental + retail SaaS.",
  "private": true,
  "dependencies": {
    "@midwayjs/bootstrap": "^3.20.3",
    "@midwayjs/core": "^3.20.3",
    "@midwayjs/cron": "^3.20.3",
    "@midwayjs/info": "^3.20.3",
    "@midwayjs/koa": "^3.20.3",
    "@midwayjs/logger": "^3.4.2",
    "@midwayjs/static-file": "^3.20.3",
    "@midwayjs/typeorm": "^3.20.3",
    "@midwayjs/validate": "^3.20.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@midwayjs/mock": "^3.20.3",
    "@types/jest": "^29.5.14",
    "@types/node": "22",
    "@types/pg": "^8.11.10",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mwts": "^1.3.0",
    "mwtsc": "^1.15.1",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node ./bootstrap.js",
    "dev": "cross-env NODE_ENV=local mwtsc --cleanOutDir --watch --run @midwayjs/mock/app.js --keepalive",
    "test": "cross-env NODE_ENV=unittest jest",
    "cov": "jest --coverage",
    "lint": "mwts check",
    "lint:fix": "mwts fix",
    "build": "mwtsc --cleanOutDir",
    "migration:run": "mwtsc --cleanOutDir && typeorm migration:run -d dist/core/database/data-source.js",
    "migration:revert": "mwtsc --cleanOutDir && typeorm migration:revert -d dist/core/database/data-source.js",
    "seed": "mwtsc --cleanOutDir && cross-env NODE_ENV=local node dist/core/database/seed.js",
    "check": "cd ../.. && npm run guard:backend-architecture && npm run guard:prod-config -- packages/backend/src/config/config.prod.ts"
  },
  "bin": "./bootstrap.js",
  "license": "MIT"
}
