{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "es2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "inlineSourceMap": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "pretty": true,
    "declaration": false,
    "typeRoots": ["typings", "./node_modules/@types"],
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "test"]
}
